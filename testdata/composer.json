{
    "name": "test/project",
    "description": "A test project",
    "type": "project",
    "license": "MIT",
    "homepage": "https://example.com/test-project",
    "authors": [
        {
            "name": "John Doe",
            "email": "john@example.com",
            "homepage": "https://johndoe.dev",
            "role": "Developer"
        },
        {
            "name": "Jane Smith",
            "email": "jane@example.com"
        }
    ],
    "support": {
        "issues": "https://github.com/test/project/issues",
        "source": "https://github.com/test/project",
        "docs": "https://docs.example.com"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "doctrine/orm": "^3.0",
        "twig/twig": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "replace": {
        "symfony/polyfill-php72": "*"
    },
    "conflict": {
        "old/broken-pkg": "<2.0"
    },
    "provide": {
        "psr/log-implementation": "1.0"
    },
    "suggest": {
        "ext-intl": "Required for internationalization support"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/vendor/private-pkg"
        }
    ],
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "require": "7.0.*",
            "allow-contrib": false,
            "docker": true
        }
    }
}
